{
  "expo": {
    "name": "CiCi",
    "slug": "cms",
    "version": "1.0.0",
    "runtimeVersion": "54.0.0",
    "updates": {
      "url": "https://u.expo.dev/dcddb7bc-4b64-4205-9fc1-60bb269e6273",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "corecms",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.corecms.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CiCi cần vị trí để xác minh check-in của bạn.",
        "NSCameraUsageDescription": "CiCi cần camera để chụp ảnh xác thực khuôn mặt khi check-in.",
        "NSPhotoLibraryUsageDescription": "CiCi cần quyền truy cập ảnh để cập nhật ảnh đại diện.",
        "NSFaceIDUsageDescription": "CiCi sử dụng Face ID để xác thực nhanh hơn.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.corecms.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CiCi cần vị trí để xác minh check-in."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "CiCi cần camera để xác thực khuôn mặt."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C84D71"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "dcddb7bc-4b64-4205-9fc1-60bb269e6273"
      }
    },
    "owner": "s-p-a-r-k-d-e-v"
  }
}
