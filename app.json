{
  "expo": {
    "name": "CoreCMS Mobile",
    "slug": "corecms-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "corecms",
    "newArchEnabled": false,
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C252E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.corecms.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CoreCMS cần vị trí để xác minh check-in của bạn.",
        "NSCameraUsageDescription": "CoreCMS cần camera để chụp ảnh xác thực khuôn mặt khi check-in.",
        "NSPhotoLibraryUsageDescription": "CoreCMS cần quyền truy cập ảnh để cập nhật ảnh đại diện.",
        "NSFaceIDUsageDescription": "CoreCMS sử dụng Face ID để xác thực nhanh hơn."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C252E"
      },
      "package": "com.corecms.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CoreCMS cần vị trí để xác minh check-in."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "CoreCMS cần camera để xác thực khuôn mặt."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00A76F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7d92a563-a2fb-4115-a22c-6095caf32a4c"
      }
    }
  }
}
